{
  "id": "phpunit",
  "version": "1.0.0",
  "name": "PHPUnit",
  "description": "Installs the PHPUnit application.",
  "documentationURL": "http://github.com/jjs105/devcontainers/tree/main/features/src/phpunit",
  "licenseURL": "http://github.com/jjs105/devcontainers/tree/main/LICENSE",
  "keywords": [
    "PHP", "PHPUnit", "Testing", "Unit Testing"
  ],
  "dependsOn": {
    "ghcr.io/jjs105/devcontainers/features/jjs-devcontainer:1.0.0": {
    }
  },
  "installsAfter": [],
  "options": {
    "version": {
      "type": "string",
      "description": "The version to install.",
      "default": "latest",
      "enum": [
        "latest",
        "11",
        "10",
        "9"
      ]
    },
    "install-php": {
      "type": "string",
      "description": "Whether to install supporting PHP packages.",
      "default": "false",
      "enum": [
        "false",
        "cli",
        "all"
      ]
    }
  }
}